# HearthOS Environment Variables
# Copy to .env and adjust for your environment.
# Use --env-file flag: deno serve -A --env-file=.env _fresh/server.js

# ─── Server-Side Only ───────────────────────────────────────────
# Used in route handlers and farmos-client.ts. NOT available in islands.
FARMOS_GATEWAY_URL=http://localhost:5050

# ─── Client-Side (Inlined at Build Time) ────────────────────────
# FRESH_PUBLIC_* variables are inlined during `deno task build`.
# They become compile-time constants in island code.
# They CANNOT be read at runtime in islands.
FRESH_PUBLIC_SIGNALR_HUB=http://localhost:5050/hubs/kitchen
FRESH_PUBLIC_POLL_INTERVAL_MS=30000
